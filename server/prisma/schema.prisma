generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model activities {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  action      String?   @db.VarChar(255)
  entity_type String?   @db.VarChar(50)
  entity_id   String?   @db.Uuid
  metadata    Json?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model applications {
  id                        String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id                String?                     @db.Uuid
  course_id                 String?                     @db.Uuid
  status                    String?                     @default("draft") @db.VarChar(50)
  stage                     String?                     @default("preparation") @db.VarChar(50)
  application_fee           Decimal?                    @db.Decimal(12, 2)
  submission_date           DateTime?                   @db.Date
  decision_date             DateTime?                   @db.Date
  remarks                   String?
  assigned_to               String?                     @db.Uuid
  created_at                DateTime?                   @default(now()) @db.Timestamp(6)
  updated_at                DateTime?                   @default(now()) @db.Timestamp(6)
  deleted_at                DateTime?                   @db.Timestamp(6)
  institution_id            String?                     @db.Uuid
  intake                    String?                     @db.VarChar(50)
  application_stage_history application_stage_history[]
  users                     users?                      @relation(fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
  courses                   courses?                    @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  institutions              institutions?               @relation(fields: [institution_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students                  students?                   @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documents                 documents[]
  invoices                  invoices[]
  notes                     notes[]
  tasks                     tasks[]
  visa_applications         visa_applications[]

  @@index([status], map: "idx_applications_status")
}

model courses {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institution_id String?        @db.Uuid
  name           String         @db.VarChar(200)
  level          String?        @db.VarChar(50)
  duration       String?        @db.VarChar(50)
  tuition_fee    Decimal?       @db.Decimal(12, 2)
  requirements   String?
  created_at     DateTime?      @default(now()) @db.Timestamp(6)
  applications   applications[]
  institutions   institutions?  @relation(fields: [institution_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model documents {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id          String?            @db.Uuid
  application_id      String?            @db.Uuid
  file_name           String?            @db.VarChar(255)
  file_url            String
  doc_type            String?            @db.VarChar(100)
  uploaded_by         String?            @db.Uuid
  created_at          DateTime?          @default(now()) @db.Timestamp(6)
  deleted_at          DateTime?          @db.Timestamp(6)
  file_size           Int?
  rejection_reason    String?
  verification_status String?            @db.VarChar(50)
  academic_records    academic_records[]
  applications        applications?      @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students            students?          @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users?             @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model institutions {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String         @db.VarChar(200)
  country      String?        @db.VarChar(100)
  city         String?        @db.VarChar(100)
  ranking      Int?
  website      String?
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  applications applications[]
  courses      courses[]
}

model invoices {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id     String?       @db.Uuid
  application_id String?       @db.Uuid
  amount         Decimal       @db.Decimal(12, 2)
  status         String?       @default("unpaid") @db.VarChar(50)
  due_date       DateTime?     @db.Date
  created_at     DateTime?     @default(now()) @db.Timestamp(6)
  deleted_at     DateTime?     @db.Timestamp(6)
  applications   applications? @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students       students?     @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments       payments[]
}

model leads {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String?          @db.VarChar(150)
  phone            String?          @db.VarChar(20)
  country_interest String?          @db.VarChar(100)
  course_interest  String?          @db.VarChar(150)
  status           String?          @default("new") @db.VarChar(50)
  assigned_to      String?          @db.Uuid
  source           String?          @db.VarChar(100)
  notes_text       String?          @db.Text@map("notes")
  created_at       DateTime?        @default(now()) @db.Timestamp(6)
  updated_at       DateTime?        @default(now()) @db.Timestamp(6)
  deleted_at       DateTime?        @db.Timestamp(6)
  first_name       String?          @db.VarChar(100)
  middle_name      String?          @db.VarChar(100)
  last_name        String?          @db.VarChar(100)
  next_followup_at DateTime?        @db.Timestamp(6)
  lead_followups   lead_followups[]
  users            users?           @relation(fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes            notes[]
  students         students?
  tasks            tasks[]

  @@index([deleted_at], map: "idx_leads_deleted_at")
  @@index([status], map: "idx_leads_status")
}

model notes {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id        String?       @db.Uuid
  student_id     String?       @db.Uuid
  application_id String?       @db.Uuid
  content        String
  created_by     String?       @db.Uuid
  created_at     DateTime?     @default(now()) @db.Timestamp(6)
  applications   applications? @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users?        @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leads          leads?        @relation(fields: [lead_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students       students?     @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model payments {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id            String?   @db.Uuid
  amount                Decimal?  @db.Decimal(12, 2)
  payment_method        String?   @db.VarChar(50)
  transaction_reference String?
  paid_at               DateTime? @default(now()) @db.Timestamp(6)
  invoices              invoices? @relation(fields: [invoice_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model roles {
  id    Int     @id @default(autoincrement())
  name  String  @unique @db.VarChar(50)
  users users[]
}

model students {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id             String?               @unique @db.Uuid
  email               String?               @db.VarChar(150)
  phone               String?               @db.VarChar(20)
  date_of_birth       DateTime?             @db.Date
  passport_number     String?               @db.VarChar(50)
  address             String?
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  updated_at          DateTime?             @default(now()) @db.Timestamp(6)
  deleted_at          DateTime?             @db.Timestamp(6)
  first_name          String?               @db.VarChar(100)
  middle_name         String?               @db.VarChar(100)
  last_name           String?               @db.VarChar(100)
  gender              String?               @db.VarChar(20)
  nationality         String?               @db.VarChar(100)
  passport_expiry     DateTime?             @db.Date
  preferred_country   String?               @db.VarChar(100)
  preferred_course    String?               @db.VarChar(255)
  status              String?               @default("pending") @db.VarChar(50)
  academic_records    academic_records[]
  activity_logs       activity_logs[]
  applications        applications[]
  documents           documents[]
  english_test_scores english_test_scores[]
  invoices            invoices[]
  notes               notes[]
  student_notes       student_notes[]
  leads               leads?                @relation(fields: [lead_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tasks               tasks[]
  visa_applications   visa_applications[]
  work_experiences    work_experiences[]

  @@index([deleted_at], map: "idx_students_deleted_at")
}

model tasks {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String?        @db.VarChar(255)
  description     String?
  assigned_to     String?        @db.Uuid
  lead_id         String?        @db.Uuid
  student_id      String?        @db.Uuid
  application_id  String?        @db.Uuid
  due_date        DateTime?      @db.Timestamp(6)
  status          String?        @default("todo") @db.VarChar(50)
  created_at      DateTime?      @default(now()) @db.Timestamp(6)
  deleted_at      DateTime?      @db.Timestamp(6)
  organization_id String?        @db.Uuid
  priority        String?        @db.VarChar(50)
  category        String?        @db.VarChar(50)
  applications    applications?  @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users?         @relation(fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leads           leads?         @relation(fields: [lead_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students        students?      @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([due_date], map: "idx_tasks_due_date")
}

model users {
  id                        String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                     String                      @unique @db.VarChar(150)
  phone                     String?                     @db.VarChar(20)
  password_hash             String
  role_id                   Int?
  is_active                 Boolean?                    @default(true)
  created_at                DateTime?                   @default(now()) @db.Timestamp(6)
  updated_at                DateTime?                   @default(now()) @db.Timestamp(6)
  organization_id           String?                     @db.Uuid
  first_name                String?                     @db.VarChar(100)
  middle_name               String?                     @db.VarChar(100)
  last_name                 String?                     @db.VarChar(100)
  activities                activities[]
  activity_logs             activity_logs[]
  application_stage_history application_stage_history[]
  applications              applications[]
  documents                 documents[]
  lead_followups            lead_followups[]
  leads                     leads[]
  notes                     notes[]
  notifications             notifications[]
  student_notes             student_notes[]
  tasks                     tasks[]
  roles                     roles?                      @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model academic_records {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id            String?    @db.Uuid
  qualification         String?    @db.VarChar(255)
  institution_name      String?    @db.VarChar(255)
  country               String?    @db.VarChar(100)
  start_year            Int?
  completion_year       Int?
  grade                 String?    @db.VarChar(100)
  created_at            DateTime?  @default(now()) @db.Timestamp(6)
  document_id           String?    @db.Uuid
  level                 String?    @db.VarChar(100)
  school_name           String?    @db.VarChar(255)
  college_name          String?    @db.VarChar(255)
  university_name       String?    @db.VarChar(255)
  affiliated_college    String?    @db.VarChar(255)
  stream_faculty        String?    @db.VarChar(255)
  board_university      String?    @db.VarChar(255)
  degree_program        String?    @db.VarChar(255)
  major_specialization  String?    @db.VarChar(255)
  major_subjects        String?
  thesis_title          String?
  semester_wise_gpa     String?
  final_cgpa_percentage String?
  gpa_percentage        String?    @db.VarChar(50)
  division_grade        String?    @db.VarChar(50)
  enrollment_date       DateTime?  @db.Date
  graduation_date       DateTime?  @db.Date
  documents             documents? @relation(fields: [document_id], references: [id], onUpdate: NoAction)
  students              students?  @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([document_id], map: "idx_academic_records_document_id")
  @@index([student_id], map: "idx_academic_records_student_id")
}

model activity_logs {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?        @db.Uuid
  user_id         String?        @db.Uuid
  student_id      String?        @db.Uuid
  entity_type     String?        @db.VarChar(100)
  entity_id       String?        @db.Uuid
  action          String?        @db.VarChar(100)
  description     String?
  created_at      DateTime?      @default(now()) @db.Timestamp(6)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students        students?      @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users?         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model application_stage_history {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id     String?             @db.Uuid
  stage_id           String?             @db.Uuid
  changed_by         String?             @db.Uuid
  remarks            String?
  changed_at         DateTime?           @default(now()) @db.Timestamp(6)
  applications       applications?       @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users              users?              @relation(fields: [changed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  application_stages application_stages? @relation(fields: [stage_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model application_stages {
  id                        String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id           String?                     @db.Uuid
  name                      String?                     @db.VarChar(100)
  sort_order                Int?
  application_stage_history application_stage_history[]
  organizations             organizations?              @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model english_test_scores {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id    String?   @db.Uuid
  exam_type     String?   @db.VarChar(50)
  overall_score Decimal?  @db.Decimal(5, 2)
  listening     Decimal?  @db.Decimal(5, 2)
  reading       Decimal?  @db.Decimal(5, 2)
  writing       Decimal?  @db.Decimal(5, 2)
  speaking      Decimal?  @db.Decimal(5, 2)
  exam_date     DateTime? @db.Date
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  students      students? @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model lead_followups {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id       String?   @db.Uuid
  followup_date DateTime? @db.Timestamp(6)
  notes         String?
  status        String?   @db.VarChar(50)
  created_by    String?   @db.Uuid
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  users         users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leads         leads?    @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model notifications {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  title       String    @db.VarChar(255)
  message     String
  is_read     Boolean?  @default(false)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  type        String    @default("info") @db.VarChar(255)
  action_url  String?
  entity_id   String?   @db.Uuid
  entity_type String?   @db.VarChar(100)
  users       users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model organizations {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String               @db.VarChar(255)
  email              String?              @db.VarChar(255)
  phone              String?              @db.VarChar(50)
  address            String?
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  updated_at         DateTime?            @default(now()) @db.Timestamp(6)
  activity_logs      activity_logs[]
  application_stages application_stages[]
  tasks              tasks[]
}

model student_notes {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id String?   @db.Uuid
  created_by String?   @db.Uuid
  note       String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students   students? @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model visa_applications {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id     String?       @db.Uuid
  application_id String?       @db.Uuid
  visa_type      String?       @db.VarChar(100)
  lodged_date    DateTime?     @db.Date
  decision_date  DateTime?     @db.Date
  status         String?       @db.VarChar(50)
  remarks        String?
  created_at     DateTime?     @default(now()) @db.Timestamp(6)
  applications   applications? @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students       students?     @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model work_experiences {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id       String?   @db.Uuid
  company_name     String?   @db.VarChar(255)
  position         String?   @db.VarChar(255)
  start_date       DateTime? @db.Date
  end_date         DateTime? @db.Date
  responsibilities String?
  students         students? @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
